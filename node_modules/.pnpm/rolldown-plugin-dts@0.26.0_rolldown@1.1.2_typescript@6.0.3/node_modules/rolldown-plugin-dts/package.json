{
  "name": "rolldown-plugin-dts",
  "type": "module",
  "version": "0.26.0",
  "description": "A Rolldown plugin to generate and bundle dts files.",
  "author": "Kevin Deng <sxzz@sxzz.moe>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/sxzz",
  "homepage": "https://github.com/sxzz/rolldown-plugin-dts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sxzz/rolldown-plugin-dts.git"
  },
  "bugs": {
    "url": "https://github.com/sxzz/rolldown-plugin-dts/issues"
  },
  "keywords": [
    "rolldown",
    "plugin",
    "dts",
    "typescript",
    "vue",
    "jsdoc"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./internal": "./dist/internal.mjs",
    "./tsc": "./dist/tsc.mjs",
    "./tsc-context": "./dist/tsc-context.mjs",
    "./tsc-worker": "./dist/tsc-worker.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "peerDependencies": {
    "@ts-macro/tsc": "^0.3.6",
    "@typescript/native-preview": ">=7.0.0-dev.20260325.1",
    "rolldown": "^1.0.0",
    "typescript": "^5.0.0 || ^6.0.0",
    "vue-tsc": "~3.2.0 || ~3.3.0"
  },
  "peerDependenciesMeta": {
    "@ts-macro/tsc": {
      "optional": true
    },
    "@typescript/native-preview": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "vue-tsc": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/generator": "^8.0.0",
    "@babel/helper-validator-identifier": "^8.0.0",
    "@babel/parser": "^8.0.0",
    "ast-kit": "^3.0.0",
    "birpc": "^4.0.0",
    "dts-resolver": "^3.0.0",
    "get-tsconfig": "5.0.0-beta.5",
    "obug": "^2.1.3"
  },
  "devDependencies": {
    "@babel/types": "^8.0.0",
    "@jridgewell/source-map": "^0.3.11",
    "@sxzz/eslint-config": "^8.2.0",
    "@sxzz/prettier-config": "^2.3.1",
    "@sxzz/test-utils": "^0.5.18",
    "@types/node": "^25.9.3",
    "@typescript/native-preview": "7.0.0-dev.20260616.1",
    "@volar/typescript": "^2.4.28",
    "@vue/language-core": "^3.3.5",
    "arktype": "^2.2.0",
    "bumpp": "^11.1.0",
    "diff": "^9.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "rolldown": "^1.1.1",
    "rolldown-plugin-require-cjs": "^0.4.1",
    "rollup-plugin-dts": "^6.4.1",
    "tsdown": "^0.22.2",
    "tsnapi": "^0.3.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5",
    "zod": "^4.4.3"
  },
  "prettier": "@sxzz/prettier-config",
  "scripts": {
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsgo --noEmit",
    "format": "prettier --cache --write .",
    "release": "bumpp"
  }
}