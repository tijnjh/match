#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/thuisman/Projects/match/node_modules/.pnpm/tsdown@0.22.3_typescript@6.0.3/node_modules/tsdown/node_modules:/home/thuisman/Projects/match/node_modules/.pnpm/tsdown@0.22.3_typescript@6.0.3/node_modules:/home/thuisman/Projects/match/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/thuisman/Projects/match/node_modules/.pnpm/tsdown@0.22.3_typescript@6.0.3/node_modules/tsdown/node_modules:/home/thuisman/Projects/match/node_modules/.pnpm/tsdown@0.22.3_typescript@6.0.3/node_modules:/home/thuisman/Projects/match/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../tsdown/dist/run.mjs" "$@"
else
  exec node  "$basedir/../tsdown/dist/run.mjs" "$@"
fi
